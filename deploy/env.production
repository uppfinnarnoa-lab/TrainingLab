# ─────────────────────────────────────────────────────────────────────────────
# TrainingLab — Production Environment Variables
# Copy this file to /var/www/traininglab/.env on the server and fill in values.
# NEVER commit this file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Create a dedicated DB user (not postgres superuser).
DATABASE_URL="postgresql://traininglab:CHANGE_ME@localhost:5432/traininglab"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_-base64_32"

# Your production domain (no trailing slash)
NEXTAUTH_URL="https://yourdomain.com"

# ── Strava ────────────────────────────────────────────────────────────────────
# Register at: https://developers.strava.com/
# Set redirect URI to: https://yourdomain.com/api/strava/callback
STRAVA_CLIENT_ID="your_strava_client_id"
STRAVA_CLIENT_SECRET="your_strava_client_secret"

# ── Garmin ────────────────────────────────────────────────────────────────────
# Register at: https://developer.garmin.com/health-api/
# Set redirect URI to: https://yourdomain.com/api/garmin/callback
GARMIN_CLIENT_ID="your_garmin_client_id"
GARMIN_CLIENT_SECRET="your_garmin_client_secret"

# ── AI (optional server-side defaults) ────────────────────────────────────────
# Users can set their own keys in the app UI (Settings → AI Coach).
# These are fallback defaults if no user key is configured.
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT="3000"
