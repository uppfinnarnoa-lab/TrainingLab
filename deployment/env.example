# TrainingLab — Production Environment Variables
# Copy to /var/www/traininglab/.env.local on the server and fill in all values.
# NEVER commit the filled-in .env.local to git.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://traininglab:CHANGE_ME@localhost:5432/traininglab"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
NEXTAUTH_URL="https://training.helgars.se"

# ── Strava ────────────────────────────────────────────────────────────────────
# Register at: https://developers.strava.com/
# Set Authorization Callback Domain to: training.helgars.se
STRAVA_CLIENT_ID="your_strava_client_id"
STRAVA_CLIENT_SECRET="your_strava_client_secret"
STRAVA_REDIRECT_URI="https://training.helgars.se/api/strava/callback"

# ── Garmin ────────────────────────────────────────────────────────────────────
# Register at: https://developer.garmin.com/health-api/
GARMIN_CLIENT_ID="your_garmin_client_id"
GARMIN_CLIENT_SECRET="your_garmin_client_secret"

# ── AI ────────────────────────────────────────────────────────────────────────
# Users can also set their own keys in Settings → AI Coach.
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
