# TrainingLab — Production Environment Variables
# Copy to /var/www/traininglab/.env.local and fill in the required values.
# NEVER commit the filled-in .env.local to git.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://traininglab:CHANGE_ME@localhost:5432/traininglab"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"
NEXTAUTH_URL="https://training.helgars.se"

# ── Encryption key (for Strava/Garmin token storage) ─────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY="CHANGE_ME"

# ── Strava (developer / app-level credentials) ───────────────────────────────
# OPTION A — Set here as env vars (simpler for single-admin setup):
#   Register at https://www.strava.com/settings/api
#   Set Authorization Callback Domain to: training.helgars.se
# OPTION B — Leave blank and set via Settings → Strava in the app UI (admin only).
#   If set in UI, env vars are ignored.
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_REDIRECT_URI="https://training.helgars.se/api/strava/callback"

# These are app-level OAuth credentials shared by all users.
# Individual users connect their own Strava accounts via OAuth — each user's
# access tokens are completely separate and private.

# ── Garmin (optional — developer credentials, same pattern as Strava) ─────────
# Register at https://developer.garmin.com/health-api/
# Can also be configured in Settings UI instead of env vars.
GARMIN_CLIENT_ID=""
GARMIN_CLIENT_SECRET=""

# ── AI (optional — users set their own keys in Settings → AI Coach) ───────────
# You can set server-level defaults here, but per-user keys in the UI take priority.
# Most users will add their own keys — leave blank unless you want a shared fallback.
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""

# ── Strava webhook verification token (optional) ──────────────────────────────
# Only needed if using Strava webhook push subscription.
# Set to any random string, then register with Strava (see README §9).
STRAVA_WEBHOOK_VERIFY_TOKEN=""
