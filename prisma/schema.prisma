generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  pending
  active
  rejected
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String?
  status       UserStatus @default(pending)
  isAdmin      Boolean    @default(false)
  createdAt    DateTime   @default(now())

  stravaAccount      StravaAccount?
  garminAccount      GarminAccount?
  garminDailies      GarminDailySummary[]
  activities         Activity[]
  plannedWorkouts    PlannedWorkout[]
  workoutTemplates   WorkoutTemplate[]
  sportCategories    SportCategory[]
  workoutTypes       WorkoutType[]
  raceRecords        RaceRecord[]
  trainingBlocks     TrainingBlock[]
  conversations      Conversation[]
  aiSettings         AISettings?
  athleteProfile     AthleteProfile?
  appConfig          AppConfig?
  fitnessCache       FitnessCache?
  sessions           Session[]
  trainingGoals      TrainingGoal[]
}

model AthleteProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  weightKg         Float?
  heightCm         Float?
  dateOfBirth      DateTime? @db.Date
  sex              String?   // "male" | "female" | "other"
  maxHeartRate     Int?
  restingHeartRate Int?
  manualLT1HR      Int?      // User-set LT1 (aerobic threshold) override — only overrides, estimate never writes here
  manualLT2HR      Int?      // User-set LT2 (lactate threshold) override — only overrides, estimate never writes here
  maxHRArtifactCap Int?      // HR readings above this are treated as sensor artifacts (default 190)
  primaryGoal      String?
  yearsTraining    Int?
  annualGoals      Json?     // { "2026": { "Run": 2000, "Ride": 3000 }, ... } km targets per year per sport
  paceUnit         String    @default("min_per_km") // "min_per_km" | "min_per_mi" | "km_h"
  paceUnitBySport  Json?     // { "Run": "min_per_km", "Ride": "km_h" } per-sport override
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StravaAccount {
  id           String    @id @default(cuid())
  userId       String    @unique
  athleteId    BigInt    @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  lastSyncAt   DateTime?
  totalSynced  Int       @default(0)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GarminAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  displayName  String?  // Garmin Connect username — needed for Connect API path params
  accessToken  String   // AES-256-GCM encrypted OAuth2 Bearer token
  refreshToken String   // AES-256-GCM encrypted OAuth2 refresh token
  expiresAt    DateTime // access token expiry
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GarminDailySummary {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime @db.Date
  restingHR       Int?
  hrvNightly      Float?
  hrvBalance      String?  // "Balanced" | "Low" | "Unbalanced"
  sleepScore      Int?
  sleepDuration   Int?     // seconds
  sleepDeep       Int?     // seconds
  sleepLight      Int?     // seconds
  sleepRem        Int?     // seconds
  sleepAwake      Int?     // seconds
  bodyBattery       Int?     // 0-100
  respirationRate   Float?
  stressAvg         Int?     // 0-100 average daily stress level
  trainingReadiness Int?     // 0-100 Garmin training readiness score
  spo2Avg           Float?   // % avg blood oxygen (SpO2)
  steps             Int?     // total daily steps
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Activity {
  id           String   @id
  userId       String
  stravaId     BigInt   @unique
  name         String
  description  String?
  sportType    String
  startDate    DateTime
  startDateLocal DateTime
  timezone     String

  distance           Float
  movingTime         Int
  elapsedTime        Int
  totalElevationGain Float

  averageSpeed  Float?
  maxSpeed      Float?
  averageCadence Float?
  averageWatts  Float?
  weightedAverageWatts Float?

  averageHeartrate Float?
  maxHeartrate     Float?

  sufferScore      Int?
  perceivedExertion Int?
  workoutType      Int?
  customTypeName   String?    // user-overridden type for color classification
  isRace           Boolean @default(false)
  mapPolyline      String?

  splitsMetric       Json?
  laps               Json?
  bestEfforts        Json?
  splitDetailFetched Boolean @default(false)

  trainingLoad    Float?
  intensityFactor Float?
  hrrSeconds      Int?    // Heart Rate Recovery — HR drop 60s after peak effort

  weatherTemp   Float?
  weatherWind   Float?
  weatherPrecip Float?
  weatherCode   Int?

  startLat  Float?
  startLng  Float?

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchedPlannedId String?
  matchedPlanned   PlannedWorkout? @relation(fields: [matchedPlannedId], references: [id])
  stream           ActivityStream?

  @@index([userId, startDate])
  @@index([userId, sportType])
  @@index([userId, isRace])
  @@index([userId, startDate, sportType])  // composite for filtered stats queries
}

model ActivityStream {
  id         String   @id @default(cuid())
  activityId String   @unique
  fetchedAt  DateTime @default(now())
  time       Json?
  distance   Json?
  altitude   Json?
  heartrate  Json?
  velocity   Json?
  cadence    Json?
  watts      Json?
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model SportCategory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String
  icon      String
  isDefault Boolean  @default(false)
  order     Int      @default(0)
  isRunningRelated Boolean @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutTypes WorkoutType[]
  templates    WorkoutTemplate[]
}

model WorkoutType {
  id      String  @id @default(cuid())
  userId  String
  sportId String
  name    String
  color   String?
  order   Int     @default(0)
  defaultZone Int?
  isShared    Boolean @default(false) // shared across all sports — edits propagate to every sport's copy
  sport   SportCategory   @relation(fields: [sportId], references: [id])
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  templates WorkoutTemplate[]
  planned PlannedWorkout[]
}

model WorkoutTemplate {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  sportId     String
  typeId      String?
  color       String?

  estimatedDistance         Float?
  estimatedDuration         Int?
  estimatedTSS              Float?
  estimatedZoneDistribution Json?

  sections WorkoutSection[]
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport    SportCategory    @relation(fields: [sportId], references: [id])
  type     WorkoutType?     @relation(fields: [typeId], references: [id])
  planned  PlannedWorkout[]

  @@index([userId, sportId])
}

model WorkoutSection {
  id         String  @id @default(cuid())
  templateId String
  order      Int
  name       String
  durationType  String  // "time" | "distance" | "open"
  duration      Int?
  distance      Float?
  repetitions   Int?
  zoneType      String? // "hr_zone" | "pace_zone" | "power_zone" | "rpe"
  targetZone    Int?
  targetPaceLow  Float?
  targetPaceHigh Float?
  targetHRLow   Int?
  targetHRHigh  Int?
  targetRPE     Int?
  notes         String?
  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, order])
}

model PlannedWorkout {
  id         String   @id @default(cuid())
  userId     String
  templateId String?
  typeId     String?
  date       DateTime @db.Date
  name       String
  sportType  String
  notes      String?
  targetDistance  Float?
  targetDuration  Int?
  targetIntensity String?
  color           String?

  status       String    @default("planned") // "planned"|"completed"|"missed"|"partial"
  missedReason String?
  missedNote   String?
  markedAt     DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        WorkoutTemplate? @relation(fields: [templateId], references: [id])
  type            WorkoutType?     @relation(fields: [typeId], references: [id])
  matchedActivity Activity[]

  @@index([userId, date])
  @@index([userId, status])
}

model RaceRecord {
  id               String   @id @default(cuid())
  userId           String
  distance         String
  distanceM        Float
  time             Int      // seconds
  date             DateTime @db.Date
  eventName        String?
  stravaActivityId String?
  notes            String?
  isManual         Boolean  @default(false)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, distance])
  @@index([userId, distanceM])
}

model TrainingBlock {
  id          String   @id @default(cuid())
  userId      String
  name        String
  blockType   String   // "base"|"build"|"peak"|"taper"|"custom"
  color       String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  targetRaceId String?
  notes       String?
  targetKmPerWeek   Float?
  targetIntensity   String? // "polarized"|"pyramidal"|"threshold"
  archived          Boolean @default(false)
  actualKm          Float?
  actualTimeSec     Int?
  actualTSS         Float?
  actualCompletionRate Float?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([userId, archived])
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           String      // "user"|"assistant"|"system"
  content        String
  createdAt      DateTime    @default(now())
  tokensUsed     Int?
  estimatedCostUsd Float?
  modelUsed      String?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AISettings {
  id           String  @id @default(cuid())
  userId       String  @unique
  provider     String  @default("gemini") // "claude"|"gemini"|"nvidia"
  claudeApiKey String?
  geminiApiKey String?
  nvidiaApiKey String?
  nvidiaModel  String? // default: "nvidia/llama-3.1-nemotron-70b-instruct-hq"
  groqApiKey   String?
  groqModel    String? // default: "llama-3.3-70b-versatile"
  systemPrompt String?
  // Claude budget
  monthlyBudgetUsd     Float @default(5.0)
  currentMonthSpendUsd Float @default(0.0)
  // Gemini budget (paid tier)
  geminiMonthlyBudgetUsd     Float @default(5.0)
  geminiCurrentMonthSpendUsd Float @default(0.0)
  spendResetAt DateTime @default(now())
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Cached fitness metrics — recomputed after each sync, read by stats + coach
model FitnessCache {
  id           String   @id @default(cuid())
  userId       String   @unique
  vo2max       Float
  vdot         Float
  confidence   String
  method       String
  maxHR        Int
  restHR       Int
  thresholdHR  Int?
  zones        Json     // { z1: [lo,hi], z2: [lo,hi], z3, z4, z5 }
  paces        Json     // { easy, marathon, threshold, interval, repetition }
  // Performance cache — updated after every Strava sync
  atl              Float?   // Acute Training Load (7-day)
  ctl              Float?   // Chronic Training Load (42-day)
  tsb              Float?   // Training Stress Balance = CTL - ATL
  acwr             Float?   // Acute:Chronic Workload Ratio
  weeklyVolumeJson Json?    // { weekKey: { sport: { km, timeSec } } } last 16 weeks
  zoneSecondsJson  Json?    // { z1, z2, z3, z4, z5 } seconds last 12 weeks
  polarisationJson Json?    // { z1Pct, z2Pct, z3Pct } Seiler 3-zone
  predictionsJson      Json?    // [{ label, meters, peak, today, riegel, rangeLo, rangeHi }]
  vo2maxBreakdownJson  Json?    // { modelName: vdot, ... } — per-model VDOT breakdown
  extraVizJson         Json?    // { heatmapData, monthlyOverlay, intensityProfile, vdotTrend, terrainFactor, perfByDistYear }
  statZonesJson        Json?    // StatisticalZoneResult | null — activity+laps combined
  statZonesLapsJson    Json?    // StatisticalZoneResult | null — laps only
  decouplingLt1HR      Float?   // LT1 from aerobic decoupling (parallel estimate)
  decouplingRunsUsed   Int?     // how many steady-state runs contributed
  criticalSpeedMs      Float?   // Critical Speed in m/s — LT2 proxy from best efforts
  wPrimeMeters         Float?   // W' anaerobic capacity in meters
  computedAt   DateTime @default(now()) @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrainingGoal {
  id        String   @id @default(cuid())
  userId    String
  sport     String   @default("") // "" = all sports combined
  metric    String   // "distance" | "time"
  period    String   // "week" | "month" | "year"
  target    Float    // km (distance) or minutes (time)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sport, metric, period])
  @@index([userId])
}

// Integration credentials stored in DB — lets users configure everything via the UI
// without editing .env files. Env vars are used as fallback if these are empty.
model AppConfig {
  id                  String  @id @default(cuid())
  userId              String  @unique
  stravaClientId      String?
  stravaClientSecret  String?
  garminClientId      String?
  garminClientSecret  String?
  // Webhook & auto-sync
  stravaWebhookSubscriptionId  Int?     // set when Strava webhook subscription is active
  stravaWebhookToken           String?  // verify_token used when registering the subscription
  stravaAutoSyncMode           String   @default("manual") // "manual" | "webhook" | "cron"
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
